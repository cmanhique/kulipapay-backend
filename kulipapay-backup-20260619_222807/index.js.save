// ============ RECUPERAÇÃO DE SENHA ============

const passwordRecovery = require('./services/password-recovery.service');

// Solicitar recuperação
app.post('/api/auth/forgot-password', async (request, reply) => {
  try {
    const { identifier } = request.body;
    
    if (!identifier) {
      return reply.status(400).send({ error: 'IDENTIFIER_REQUIRED' });
    }
    
    const result = await passwordRecovery.requestRecovery(identifier);
    return reply.send(result);
    
  } catch (error) {
    return reply.status(500).send({ error: error.message });
  }
});

// Verificar token
app.post('/api/auth/verify-reset-token', async (request, reply) => {
  try {
    const { token } = request.body;
    
    if (!token) {
      return reply.status(400).send({ error: 'TOKEN_REQUIRED' });
    }
    
    const result = await passwordRecovery.verifyToken(token);
    return reply.send(result);
    
  } catch (error) {
    const status = error.message === 'INVALID_TOKEN' || 
                   error.message === 'TOKEN_EXPIRED' ? 400 : 500;
    return reply.status(status).send({ error: error.message });
  }
});

// Redefinir senha
app.post('/api/auth/reset-password', async (request, reply) => {
  try {
    const { token, newPassword } = request.body;
    
    if (!token || !newPassword) {
      return reply.status(400).send({ error: 'TOKEN_AND_PASSWORD_REQUIRED' });
    }
    
    const result = await passwordRecovery.resetPassword(token, newPassword);
    return reply.send(result);
    
  } catch (error) {
    const status = error.message === 'INVALID_TOKEN' || 
                   error.message === 'TOKEN_EXPIRED' ||
                   error.message === 'PASSWORD_TOO_SHORT' ? 400 : 500;
    return reply.status(status).send({ error: error.message });
  }
});

// ============ RECUPERAÇÃO DE SENHA ============


// Modelo temporário para tokens (enquanto não fazemos migration)
const resetTokens = new Map();

// Solicitar recuperação
app.post('/api/auth/forgot-password', async (request, reply) => {
  try {
    const { identifier } = request.body;
    
    if (!identifier) {
      return reply.status(400).send({ error: 'IDENTIFIER_REQUIRED' });
    }
    
    const isEmail = identifier.includes('@');
    const account = await prisma.account.findFirst({
      where: isEmail ? { email: identifier } : { phone: identifier }
    });
    
    if (!account) {
      // Por segurança, não revelar se o utilizador existe
      return reply.send({ 
        success: true, 
        message: 'Se a conta existir, receberá um código de recuperação' 
      });
    }
    
    // Gerar token de 6 dígitos
    const token = Math.floor(100000 + Math.random() * 900000).toString();
    const expiresAt = Date.now() + 15 * 60 * 1000; // 15 minutos
    
    // Guardar token
    resetTokens.set(token, {
      kpId: account.kp_id,
      expiresAt: expiresAt,
      used: false
    });
    
    // Em desenvolvimento, mostrar o token no console
    console.log('\n========================================');
    console.log('🔐 CÓDIGO DE RECUPERAÇÃO');
    console.log(`📧 Conta: ${account.email || account.phone}`);
    console.log(`🔑 Código: ${token}`);
    console.log(`⏰ Expira em: 15 minutos`);
    console.log('========================================\n');
    
    return reply.send({ 
      success: true, 
      message: 'Código de recuperação enviado',
      // Em desenvolvimento, enviar o token para facilitar testes
      ...(process.env.NODE_ENV !== 'production' && { token })
    });
    
  } catch (error) {
    console.error(error);
    return reply.status(500).send({ error: error.message });
  }
});

// Verificar token
app.post('/api/auth/verify-reset-token', async (request, reply) => {
  try {
    const { token } = request.body;
    
    if (!token) {
      return reply.status(400).send({ error: 'TOKEN_REQUIRED' });
    }
    
    const resetToken = resetTokens.get(token);
    
    if (!resetToken) {
      return reply.status(400).send({ error: 'INVALID_TOKEN' });
    }
    
    if (resetToken.used) {
      return reply.status(400).send({ error: 'TOKEN_ALREADY_USED' });
    }
    
    if (Date.now() > resetToken.expiresAt) {
      resetTokens.delete(token);
      return reply.status(400).send({ error: 'TOKEN_EXPIRED' });
    }
    
    return reply.send({ 
      valid: true, 
      kpId: resetToken.kpId 
    });
    
  } catch (error) {
    return reply.status(500).send({ error: error.message });
  }
});

// Redefinir senha
app.post('/api/auth/reset-password', async (request, reply) => {
  try {
    const { token, newPassword } = request.body;
    
    if (!token || !newPassword) {
      return reply.status(400).send({ error: 'TOKEN_AND_PASSWORD_REQUIRED' });
    }
    
    if (newPassword.length < 6) {
      return reply.status(400).send({ error: 'PASSWORD_TOO_SHORT' });
    }
    
    const resetToken = resetTokens.get(token);
    
    if (!resetToken) {
      return reply.status(400).send({ error: 'INVALID_TOKEN' });
    }
    
    if (resetToken.used) {
      return reply.status(400).send({ error: 'TOKEN_ALREADY_USED' });
    }
    
    if (Date.now() > resetToken.expiresAt) {
      resetTokens.delete(token);
      return reply.status(400).send({ error: 'TOKEN_EXPIRED' });
    }
    
    // Hash da nova senha
    const hashedPassword = await bcrypt.hash(newPassword, 12);
    
    // Atualizar senha
    await prisma.account.update({
      where: { kp_id: resetToken.kpId },
      data: { password_hash: hashedPassword }
    });
    
    // Marcar token como usado
    resetToken.used = true;
    resetTokens.set(token, resetToken);
    
    // Limpar token após 5 minutos
    setTimeout(() => {
      resetTokens.delete(token);
    }, 5 * 60 * 1000);
    
    // Invalidar todas as sessões
    await prisma.session.deleteMany({
      where: { kp_id: resetToken.kpId }
    });
    
    console.log(`✅ Senha redefinida para conta: ${resetToken.kpId}`);
    
    return reply.send({ 
      success: true, 
      message: 'Senha redefinida com sucesso' 
    });
    
  } catch (error) {
    console.error(error);
    return reply.status(500).send({ error: error.message });
  }
});

