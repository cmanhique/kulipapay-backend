{
  "name": "kulipapay-backend",
  "version": "1.0.0",
  "description": "KulipaPay Backend API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "prisma generate --schema=./prisma/schema.prisma",
    "postinstall": "prisma generate --schema=./prisma/schema.prisma",
    "migrate": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "reconcile": "node scripts/reconcile-ledger.js",
    "fix-ledger": "node scripts/fix-ledger.js"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fastify/cors": "^8.5.0",
    "@fastify/rate-limit": "^8.1.1",
    "@fastify/websocket": "^11.2.0",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.1",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "chart.js": "^4.5.1",
    "dotenv": "^16.6.1",
    "fastify": "^4.26.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.0",
    "moment": "^2.30.1",
    "pg": "^8.11.0",
    "react-chartjs-2": "^5.3.1",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.0",
    "prisma": "^5.22.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
