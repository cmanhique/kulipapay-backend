app.post('/api/auth/register', async (request, reply) => {
  try {
    const { email, phone, password, name, country = 'MZ' } = request.body;
    if (!phone || !password) return reply.status(400).send({ error: 'PHONE_AND_PASSWORD_REQUIRED' });
    
    const random = Math.floor(Math.random() * 100000000).toString().padStart(8, '0');
    const kpId = `${country}-${random}-1`;cd ~/Projects/KulipaPay/backend
cp src/index.js src/index.js.backup
    const hashedPassword = await bcrypt.hash(password, 12);
    
    const account = await prisma.account.create({
      data: { kp_id: kpId, email: email || null, phone, name: name || null, password_hash: hashedPassword, account_type: 'INDIVIDUAL', status: 'ACTIVE', country }
    });
    
    await prisma.wallet.create({ data: { kp_id: kpId, balance: 0 } });
    
    const accessToken = jwt.sign({ kpId, role: account.role }, SECRET, { expiresIn: '7d' });
    const refreshToken = crypto.randomBytes(64).toString('hex');
    
    await prisma.session.create({
      data: { kp_id: kpId, access_token: accessToken, refresh_token: refreshToken, expires_at: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000), refresh_expires_at: new Date(Date.now() + 30 * 24 * 60 * 60 * 1000) }
    });
    
    // Publicar evento
    await eventBus.publish(eventTypes.USER_CREATED, { kpId, email, phone });
    
    return reply.send({ success: true, kpId, accessToken, refreshToken });
  } catch (error) {
    if (error.code === 'P2002') return reply.status(400).send({ error: 'ACCOUNT_ALREADY_EXISTS' });
    return reply.status(500).send({ error: error.message });
  }
});

app.post('/api/auth/login', async (request, reply) => {
  try {
    const { identifier, password } = request.body;
    const isEmail = identifier.includes('@');
    const account = await prisma.account.findFirst({ where: isEmail ? { email: identifier } : { phone: identifier } });
    
    if (!account) return reply.status(401).send({ error: 'INVALID_CREDENTIALS' });
    
    const valid = await bcrypt.compare(password, account.password_hash);
    if (!valid) return reply.status(401).send({ error: 'INVALID_CREDENTIALS' });
    
    const accessToken = jwt.sign({ kpId: account.kp_id, role: account.role }, SECRET, { expiresIn: '7d' });
    const refreshToken = crypto.randomBytes(64).toString('hex');
    
    await prisma.session.deleteMany({ where: { kp_id: account.kp_id } });
    await prisma.session.create({
      data: { kp_id: account.kp_id, access_token: accessToken, refresh_token: refreshToken, expires_at: new Date(Date.now() + 7 * 24 * 60 * 60 * 1000), refresh_expires_at: new Date(Date.now() + 30 * 24 * 60 * 60 * 1000) }
    });
    
    // Publicar evento
    await eventBus.publish(eventTypes.USER_LOGIN, { kpId: account.kp_id });
    
    return reply.send({ 
      success: true, 
      accessToken, 
      refreshToken, 
      kpId: account.kp_id, 
      name: account.name,
      role: account.role 
    });
  } catch (error) {
    return reply.status(500).send({ error: error.message });
  }
});

async function authenticate(request, reply) {
  try {
    const auth = request.headers.authorization;
    if (!auth) return reply.status(401).send({ error: 'NO_TOKEN_PROVIDED' });
    const token = auth.replace('Bearer ', '');
    const session = await prisma.session.findUnique({ where: { access_token: token } });
    if (!session || session.expires_at < new Date()) return reply.status(401).send({ error: 'INVALID_OR_EXPIRED_TOKEN' });
    const decoded = jwt.verify(token, SECRET);
    request.user = decoded;
  } catch (err) {
    return reply.status(401).send({ error: 'INVALID_TOKEN' });
  }
}

app.post('/api/auth/logout', { preHandler: authenticate }, async (request, reply) => {
  const token = request.headers.authorization?.replace('Bearer ', '');
  if (token) {
    await prisma.session.deleteMany({ where: { access_token: token } });
    await eventBus.publish(eventTypes.USER_LOGOUT, { kpId: request.user.kpId });
  }
  return reply.send({ success: true });
});

