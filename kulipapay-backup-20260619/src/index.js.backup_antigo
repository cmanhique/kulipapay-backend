app.post('/api/wallet/deposit', { preHandler: authenticate }, async (request, reply) => {
  const { kpId } = request.user;
  const { amount } = request.body;
  if (!amount || amount <= 0) return reply.status(400).send({ error: 'INVALID_AMOUNT' });
  
  const wallet = await prisma.wallet.update({
    where: { kp_id: kpId },
    data: { balance: { increment: amount } }
  });
  
  // Publicar evento de depósito
  await eventBus.publish(eventTypes.DEPOSIT_CREATED, { kpId, amount, newBalance: wallet.balance });
  
  return reply.send({ success: true, balance: wallet.balance });
});

// TRANSFERÊNCIA COM EVENTOS
app.post('/api/wallet/transfer', { preHandler: authenticate }, async (request, reply) => {
  const { kpId: fromKp } = request.user;
  const { toKp, amount } = request.body;
  
  if (!toKp) return reply.status(400).send({ error: 'DESTINATION_REQUIRED' });
  if (!amount || amount <= 0) return reply.status(400).send({ error: 'INVALID_AMOUNT' });
  if (fromKp === toKp) return reply.status(400).send({ error: 'SELF_TRANSFER' });
  if (amount > 10000) return reply.status(400).send({ error: 'LIMIT_EXCEEDED' });
  
  // Publicar evento de transferência iniciada
  await eventBus.publish(eventTypes.TRANSFER_CREATED, { from: fromKp, to: toKp, amount });
  
  const result = await prisma.$transaction(async (tx) => {
    const fromWallet = await tx.wallet.findUnique({ where: { kp_id: fromKp } });
    const toWallet = await tx.wallet.findUnique({ where: { kp_id: toKp } });
    
    if (!fromWallet || !toWallet) throw new Error('WALLET_NOT_FOUND');
    if (fromWallet.balance < amount) throw new Error('INSUFFICIENT_BALANCE');
    
    await tx.wallet.update({ where: { kp_id: fromKp }, data: { balance: { decrement: amount } } });
    await tx.wallet.update({ where: { kp_id: toKp }, data: { balance: { increment: amount } } });
    
    // Publicar evento de transferência concluída
    await eventBus.publish(eventTypes.TRANSFER_COMPLETED, { from: fromKp, to: toKp, amount, status: 'success' });
    
    return { fromBalance: fromWallet.balance - amount };
  });
  
  return reply.send({ success: true, fromBalance: result.fromBalance });
});

