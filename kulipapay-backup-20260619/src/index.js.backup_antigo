// Top utilizadores por volume de transações
app.get('/api/admin/top-users', { preHandler: [authenticate, requireAdmin] }, async (request, reply) => {
  const { period = 'week', limit = 10 } = request.query;
  
  let dateFilter;
  const now = new Date();
  
  switch (period) {
    case 'day':
      dateFilter = new Date(now.setDate(now.getDate() - 1));
      break;
    case 'week':
      dateFilter = new Date(now.setDate(now.getDate() - 7));
      break;
    case 'month':
      dateFilter = new Date(now.setMonth(now.getMonth() - 1));
      break;
    default:
      dateFilter = new Date(now.setDate(now.getDate() - 30));
  }
  
  const topUsers = await prisma.$queryRaw`
    SELECT 
      a.kp_id,
      a.name,
      a.email,
      COUNT(l.id) as transaction_count,
      SUM(l.amount) as total_volume
    FROM "LedgerEntry" l
    JOIN "Account" a ON l.from_kp = a.kp_id
    WHERE l.created_at >= ${dateFilter}
    GROUP BY a.kp_id, a.name, a.email
    ORDER BY total_volume DESC
    LIMIT ${parseInt(limit)}
  `;
  
  return reply.send({ topUsers, period });
});

// Volume de transações por hora/dia
app.get('/api/admin/volume-stats', { preHandler: [authenticate, requireAdmin] }, async (request, reply) => {
  const { range = '7d' } = request.query;
  
  let days;
  switch (range) {
    case '24h': days = 1; break;
    case '7d': days = 7; break;
    case '30d': days = 30; break;
    default: days = 7;
  }
  
  const volumeStats = await prisma.$queryRaw`
    SELECT 
      DATE_TRUNC('day', created_at) as date,
      COUNT(*) as transaction_count,
      SUM(amount) as volume
    FROM "LedgerEntry"
    WHERE created_at >= NOW() - INTERVAL '${days} days'
    GROUP BY DATE_TRUNC('day', created_at)
    ORDER BY date ASC
  `;
  
  return reply.send({ volumeStats, range: days + 'd' });
});

// Atividade por hora (mapa de calor)
app.get('/api/admin/activity-heatmap', { preHandler: [authenticate, requireAdmin] }, async (request, reply) => {
  const heatmap = await prisma.$queryRaw`
    SELECT 
      EXTRACT(DOW FROM created_at) as day_of_week,
      EXTRACT(HOUR FROM created_at) as hour,
      COUNT(*) as activity_count
    FROM "LedgerEntry"
    WHERE created_at >= NOW() - INTERVAL '30 days'
    GROUP BY day_of_week, hour
    ORDER BY day_of_week, hour
  `;
  
  return reply.send({ heatmap });
});

